<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>com.gddownloader.server</string>
	<key>ProgramArguments</key>
	<array>
		<string>/bin/bash</string>
		<string>__ROOT__/scripts/run-server.sh</string>
	</array>
	<key>WorkingDirectory</key>
	<string>__ROOT__</string>
	<key>RunAtLoad</key>
	<true/>
	<key>KeepAlive</key>
	<true/>
	<key>StandardOutPath</key>
	<string>__HOME__/Library/Logs/gddownloader-server.log</string>
	<key>StandardErrorPath</key>
	<string>__HOME__/Library/Logs/gddownloader-server.err.log</string>
</dict>
</plist>
